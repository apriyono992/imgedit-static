# Salin file ini ke .env.local lalu sesuaikan

# Development: gunakan Vite proxy (/api diteruskan ke BACKEND_URL)
VITE_API_BASE_URL=/api

# URL backend — dipakai oleh Vite proxy saat dev (tidak di-expose ke browser)
BACKEND_URL=http://localhost:3000

# Port dev server Vite (default 5173)
PORT=5174

# Production: ganti dengan URL API sesungguhnya
# VITE_API_BASE_URL=https://api.yourdomain.com
